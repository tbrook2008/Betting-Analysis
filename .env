# ──────────────────────────────────────────────
# MLB Betting Analysis — Environment Variables
# ──────────────────────────────────────────────

# The Odds API key (free tier: https://the-odds-api.com)
# Used for DraftKings player prop lines
ODDS_API_KEY=your_odds_api_key_here

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Directory for diskcache and JSON output
CACHE_DIR=.cache
OUTPUT_DIR=output

# Scheduler: minutes before first game to run picks (default 60)
SCHEDULER_LEAD_MINUTES=60

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# Optional: OpenWeatherMap key for live wind data
# OWM_API_KEY=your_openweathermap_key_here

# --- Added by Assistant ---
# Allows IDEs and tools to resolve absolute imports from the project root
PYTHONPATH=.
